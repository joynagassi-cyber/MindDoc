{
  "name": "scy-forge",
  "version": "0.1.0",
  "private": true,
  "description": "SCY Forge (Synapse Cognitive Yield Forge) — plateforme d'apprentissage agentique",
  "packageManager": "pnpm@9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  }
}
