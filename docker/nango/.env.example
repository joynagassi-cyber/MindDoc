# Nango self-host — variables (copier vers .env, ne JAMAIS committer)
# Réf : docs/DEPENDENCY_MANIFEST.md §2.1
# Générer les clés : https://docs.nango.dev/host/self-hosting

NANGO_ENCRYPTION_KEY=            # 32-byte hex (généré)
NANGO_DB_HOST=postgres
NANGO_DB_PORT=5432
NANGO_DB_NAME=nango
NANGO_DB_USER=scy
NANGO_DB_PASSWORD=scy_password
NANGO_DB_SSL=false

# OAuth developer credentials (par provider connecté) se gèrent dans le dashboard Nango.
