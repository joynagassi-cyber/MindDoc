# =============================================================================
# SCY FORGE — .env.example  (COPIER vers .env, ne JAMAIS committer .env)
# Réf : docs/PROJECT_STRUCTURE.md §6, docs/DEPENDENCY_MANIFEST.md
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
APP_ENV=development
PORT=3000

# ── Database (PostgreSQL 15 + pgvector) ───────────────────────────────────────
# Cloud : Northflank (prod) | Local : docker-compose (dev)
DATABASE_URL=postgresql://scy:scy_password@localhost:5432/scy_forge
DATABASE_MAX_CONNECTIONS=10

# Desktop (mode hors-ligne, WASM)
SQLITE_PATH=./data/scy_forge.db

# ── Vectoriel (Zilliz Cloud Serverless / Milvus) ──────────────────────────────
ZILLIZ_URI=https://in03-xxxx.api.gcp-us-west1.zillizcloud.com
ZILLIZ_TOKEN=db_xxxxxxxxxxxxxxxxxxxxx

# ── LLM Providers ─────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Search Sidecars (docker-compose) ──────────────────────────────────────────
SEARXNG_API_URL=http://localhost:8080
PERPLEXICA_URL=http://localhost:3001

# ── Integration Hub (Nango self-host — PRINCIPAL) ─────────────────────────────
NANGO_SECRET_KEY=
NANGO_PUBLIC_KEY=
NANGO_HOST=http://localhost:3003

# Composio (⚠️ secondaire / POC lecture-seule — optionnel)
COMPOSIO_API_KEY=

# ── LiveKit (système vocal WebRTC) ────────────────────────────────────────────
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=ws://localhost:7880

# ── Auth (JWT, OAuth) ─────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=2592000
GOOGLE_CLIENT_ID=
GITHUB_CLIENT_ID=

# ── Observabilité (Sentry / Axiom / Langfuse) ─────────────────────────────────
SENTRY_DSN=
AXIOM_TOKEN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Infra / déploiement ───────────────────────────────────────────────────────
NORTHFLANK_API_TOKEN=
